  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^20",
    "eslint": "^9",
    "nodemon": "^3.1.7",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "typescript-eslint": "^8.53.0"
  }
}

